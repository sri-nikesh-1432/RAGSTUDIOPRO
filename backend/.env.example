# ═══════════════════════════════════════════════════════
# RAG Studio Pro - Backend Environment Configuration
# ═══════════════════════════════════════════════════════
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
# Then edit .env with your actual keys.
#
# All API keys are optional. The app works with:
#   - Local models via Ollama (no API keys needed)
#   - Free cloud models via Groq (GROQ_API_KEY)
#   - Premium cloud models via OpenAI/Anthropic/Google
# ═══════════════════════════════════════════════════════

# ─── LLM Provider API Keys ─────────────────────────────
# Get your free Groq key:  https://console.groq.com/keys
# GROQ_API_KEY=gsk_your_key_here

# Get your OpenAI key:     https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-your-key-here

# Get your Anthropic key:  https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Get your Google AI key:  https://aistudio.google.com/apikey
# GOOGLE_API_KEY=your-google-key-here

# Get your Hugging Face token: https://huggingface.co/settings/tokens
# HF_API_KEY=hf_your_token_here

# Get your OpenRouter key: https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-your-key-here

# Get your DeepSeek key:   https://platform.deepseek.com/api_keys
# DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Get your Mistral key:    https://console.mistral.ai/api-keys/
# MISTRAL_API_KEY=your-mistral-key-here

# ─── Server Configuration ───────────────────────────────
# Port the backend runs on (default: 8000)
# RAG_PORT=8000

# Allowed CORS origins (comma-separated)
RAG_CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Maximum upload file size in bytes (default: 100MB)
# RAG_MAX_UPLOAD_SIZE=104857600

# ChromaDB persistence directory
# RAG_CHROMADB_PATH=~/.rag-studio-pro/chromadb

# ─── LLM Configuration ─────────────────────────────────
# Default LLM timeout in seconds (default: 120)
# RAG_LLM_TIMEOUT=120

# Ollama server base URL (default: http://localhost:11434)
# OLLAMA_BASE_URL=http://localhost:11434

# ─── Model Configuration ───────────────────────────────
# Default embedding model (default: all-MiniLM-L6-v2)
# RAG_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Default chunking settings
# RAG_CHUNK_SIZE=500
# RAG_CHUNK_OVERLAP=50
